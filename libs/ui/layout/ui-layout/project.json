{
  "name": "ui-layout",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ui/layout/ui-layout/src",
  "prefix": "lib",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/ui/layout/ui-layout/ng-package.json",
        "tsConfig": "libs/ui/layout/ui-layout/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/ui/layout/ui-layout/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "storybook": {
      "executor": "@storybook/angular:start-storybook",
      "options": {
        "port": 4400,
        "configDir": "ui-layout/.storybook",
        "browserTarget": "ui-layout:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "build-storybook": {
      "executor": "@storybook/angular:build-storybook",
      "outputs": ["{options.outputDir}"],
      "options": {
        "outputDir": "dist/storybook/ui-layout",
        "configDir": "ui-layout/.storybook",
        "browserTarget": "ui-layout:build-storybook",
        "compodoc": false
      },
      "configurations": {
        "ci": {
          "quiet": true
        }
      }
    },
    "test-storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "test-storybook -c ui-layout/.storybook --url=http://localhost:4400"
      }
    },
    "static-storybook": {
      "executor": "@nx/web:file-server",
      "dependsOn": ["build-storybook"],
      "options": {
        "buildTarget": "ui-layout:build-storybook",
        "staticFilePath": "dist/storybook/ui-layout",
        "spa": true
      },
      "configurations": {
        "ci": {
          "buildTarget": "ui-layout:build-storybook:ci"
        }
      }
    }
  }
}
